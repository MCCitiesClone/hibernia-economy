{
  "name": "economy-explorer",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:codegen": "kysely-codegen --dialect mysql --out-file lib/db.generated.ts --camel-case"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.7.1",
    "geist": "^1.7.1",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.11.1",
    "kysely": "^0.29.2",
    "mysql2": "^3.11.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "superjson": "^2.2.6",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
