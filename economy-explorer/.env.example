# MariaDB economy DB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=economy
DB_USERNAME=economy_explorer
DB_PASSWORD=

# Keycloak OIDC
AUTH_KEYCLOAK_ISSUER=https://auth.paradaux.io/realms/minecraft
AUTH_KEYCLOAK_ID=treasury-explorer
# Public client: no secret. NextAuth still requires the field; leave empty and
# set token_endpoint_auth_method='none' on the provider.
AUTH_KEYCLOAK_SECRET=

# NextAuth — generate with `openssl rand -base64 32`
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Tenant identifier for logs / metrics (democracycraft | statecraft)
TENANT=democracycraft
