# Example Flyway configuration. Copy to flyway.conf and fill in real values
# for ad-hoc local runs (the build.gradle.kts wires URL/USER/PASSWORD from
# Gradle -P properties or env vars, which is preferred for CI/Docker).

flyway.url=jdbc:mariadb://localhost:3306/economy
flyway.user=root
flyway.password=
flyway.schemas=economy
flyway.locations=filesystem:src/main/resources/db/migration
flyway.table=flyway_schema_history
flyway.validateOnMigrate=true
